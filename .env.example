# ── SOLANA ──────────────────────────────────────────
SOLANA_RPC=https://api.devnet.solana.com
WALLET_PATH=/Users/yourname/.config/solana/id.json
PROGRAM_ID=YOUR_DEPLOYED_PROGRAM_ID_HERE

# ── ENPHASE API ──────────────────────────────────────
# Get these from developer-v4.enphase.com
ENPHASE_CLIENT_ID=your_client_id
ENPHASE_CLIENT_SECRET=your_client_secret
ENPHASE_API_KEY=your_api_key
# Set to "mock" during development, "live" for real data
ENPHASE_MODE=mock

# ── DATABASE ─────────────────────────────────────────
DATABASE_URL=postgresql://helios:helios@localhost:5432/helios

# ── ORACLE ───────────────────────────────────────────
# Poll interval in milliseconds
# 5000 = 5 seconds for dev/demo
# 900000 = 15 minutes for production
POLL_INTERVAL_MS=5000

# ── FRONTEND ─────────────────────────────────────────
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=YOUR_DEPLOYED_PROGRAM_ID_HERE
NEXT_PUBLIC_NETWORK=devnet
